---
---
callback(
  [
    {%- for post in site.posts %}
      {
        "name": {{ post.title | default: post.excerpt | strip_html | strip_newlines | normalize_whitespace | jsonify }},
        "value": {{ post.url | relative_url | jsonify }}
      }{%- unless forloop.last -%}, {%- endunless -%}
    {%- endfor %}
  ]
)
