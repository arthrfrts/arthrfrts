---
---
callback(
  [
    {%- for post in site.posts %}
      {
        "name": "{{- post.title | default: post.excerpt | strip_html | normalize_whitespace | replace: '"', '\"' -}}",
        "value": "{{- post.url | relative_url -}}"
      }{%- unless forloop.last -%}, {% endunless-%}
    {% endfor -%}
  ]
)
