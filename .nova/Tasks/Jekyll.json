{
  "actions" : {
    "build" : {
      "enabled" : true,
      "script" : "#!\/bin\/sh\nbundle update"
    },
    "clean" : {
      "enabled" : true,
      "script" : "#!\/bin\/sh\nbundle exec jekyll clean"
    },
    "run" : {
      "enabled" : true,
      "script" : "#!\/bin\/sh\nbundle exec jekyll serve --drafts --incremental"
    }
  },
  "openLogOnRun" : "fail"
}
